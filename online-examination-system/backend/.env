# Environment Variables
# Replace with your MongoDB Atlas connection string:
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/exam-system?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# For local development (requires MongoDB installed):
# MONGODB_URI=mongodb://localhost:27017/exam-system

# Port (optional, defaults to 5000)
PORT=5000